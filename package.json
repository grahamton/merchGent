  "description": "MCP server that gives merchandising agents eyes on any storefront — scrape, screenshot, and AI audit via 6 tools.",
  "type": "module",
  "bin": {
    "merch-connector": "./bin/merch-connector.js"
  },
  "files": [
    "bin/",
    "server/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
