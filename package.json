    "dotenv": "^17.2.3",
    "puppeteer": "^24.34.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
