# AI Provider — set ONE of these API keys
# ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: force a specific provider ("anthropic" or "gemini")
# MODEL_PROVIDER=gemini

# Optional: override the default model name
# MODEL_NAME=gemini-2.5-pro

# Optional: custom data directory for site memory (default: ~/.merch-connector/data/)
# MERCH_CONNECTOR_DATA_DIR=/path/to/data
