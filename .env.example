# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL_NAME=claude-sonnet-4-6   # default: claude-opus-4-6

# ─── Google Gemini ────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key_here
# MODEL_NAME=gemini-2.5-pro      # default: gemini-2.5-pro

# ─── OpenAI-compatible (OpenAI, Groq, Together AI, etc.) ─────────────────────
# OPENAI_API_KEY=sk-...          # your API key for the OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1  # optional; defaults to OpenAI's endpoint
# MODEL_NAME=gpt-4o                          # required — model identifier for the endpoint
# OPENAI_VISION=true             # enable image input (vision-capable models only)

# ─── Provider selection ───────────────────────────────────────────────────────
# MODEL_PROVIDER=anthropic       # force a provider: "anthropic", "gemini", or "openai"
#                                # auto-detected from API keys if omitted

# ─── Firecrawl (primary scraper for acquire tool) ─────────────────────────────
# FIRECRAWL_API_KEY=fc-...               # primary scraper; falls back to Puppeteer if absent

# ─── Optional ─────────────────────────────────────────────────────────────────
# MERCH_CONNECTOR_DATA_DIR=/path/to/data   # custom path for site memory files
