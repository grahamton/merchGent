# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL_NAME=claude-sonnet-4-6   # default: claude-opus-4-6

# ─── Google Gemini ────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key_here
# MODEL_NAME=gemini-2.5-pro      # default: gemini-2.5-pro

# ─── OpenAI-compatible (LM Studio, Ollama, Groq, Together AI, etc.) ──────────
# OPENAI_API_KEY=lm-studio       # LM Studio doesn't validate the key; use any string
# OPENAI_BASE_URL=http://localhost:1234/v1   # default for LM Studio
# MODEL_NAME=llama-3.1-8b-instruct          # required — must match model loaded in LM Studio
# OPENAI_VISION=true             # enable image input (vision-capable models only)

# ─── Provider selection ───────────────────────────────────────────────────────
# MODEL_PROVIDER=anthropic       # force a provider: "anthropic", "gemini", or "openai"
#                                # auto-detected from API keys if omitted

# ─── Optional ─────────────────────────────────────────────────────────────────
# MERCH_CONNECTOR_DATA_DIR=/path/to/data   # custom path for site memory files
